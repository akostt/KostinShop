<local:DialogBase x:Class="KostinShop.Views.CategoryEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KostinShop.Views"
        Title="Категория"
        Height="260" Width="420"
        MinHeight="200" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/Resources/logo.png" Width="24" Height="24"
                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed"/>
                <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="Добавление категории"
                           Style="{StaticResource DialogHeaderTitleStyle}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,0"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <TextBlock Text="Название *" Style="{StaticResource FormLabelStyle}"/>

                <TextBox x:Name="NameTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="100" TabIndex="0" Margin="0,0,0,6"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C" FontSize="12"
                           Margin="0,0,0,6" Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="24,12,24,16">
            <Button Margin="0,0,8,0" Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="90" IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" IsDefault="True" Click="SaveButton_Click" TabIndex="1"/>
        </StackPanel>
    </Grid>
</local:DialogBase>
