<local:DialogBase x:Class="KostinShop.Views.ChangeDeliveryAddressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KostinShop.Views"
        Title="Изменить адрес доставки"
        Height="320" Width="460"
        MinHeight="260" MinWidth="420"
        MaxWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/Resources/logo.png" Width="24" Height="24"
                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed"/>
                <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="✏️ Изменение адреса доставки"
                           Style="{StaticResource DialogHeaderTitleStyle}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,0">
            <StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,12,0,0">
                    <TextBlock Text="Заказ №" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="OrderIdTextBlock"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryDarkBrush}"
                               VerticalAlignment="Center" Margin="2,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Новый адрес доставки *"
                           Style="{StaticResource FormLabelStyle}" Margin="0,10,0,0"/>

                <TextBox x:Name="AddressTextBox"
                         Style="{StaticResource MultilineInputStyle}"
                         Tag="Например: г. Владимир, ул. Ленина, д. 1, кв. 5"
                         Height="72" MaxLength="500"
                         TabIndex="0"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C" FontSize="12"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Height="1" Background="#E8E8E8" Margin="24,4,24,0"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="24,12,24,16"
                    VerticalAlignment="Bottom">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="💾 Сохранить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="120" IsDefault="True"
                    Click="SaveButton_Click" TabIndex="1"/>
        </StackPanel>
    </Grid>
</local:DialogBase>
