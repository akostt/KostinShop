<local:DialogBase x:Class="KostinShop.Views.EditOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KostinShop.Views"
        Title="Редактирование заказа — KostinShop"
        Height="620" Width="680"
        MinHeight="560" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <TextBlock x:Name="TitleTextBlock"
                       Text="Редактирование заказа"
                       Style="{StaticResource DialogHeaderTitleStyle}"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,18,24,20">

                <TextBlock Text="Основные данные" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>

                <TextBlock Text="Статус *" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="StatusCombo"
                          Style="{StaticResource ComboInputStyle}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="ID_Order_Status"
                          MaxDropDownHeight="200"
                          Margin="0,0,0,12" TabIndex="2"/>

                <TextBlock Text="Адрес доставки *" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="AddressTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="500"
                         Margin="0,0,0,12" TabIndex="3"/>

                <Border Background="#E8E8E8" Height="1" Margin="0,4,0,12"/>
                <TextBlock Text="Состав заказа" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                <DataGrid x:Name="ItemsGrid"
                          Style="{StaticResource DataGridStyle}"
                          Height="160"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар"  Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Цена"   Binding="{Binding Price_at_order, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сумма"  Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#F5F7FA" CornerRadius="6" Padding="12,10" Margin="0,10,0,4">
                    <StackPanel>
                        <TextBlock Text="Добавить / изменить позицию" FontSize="12" FontWeight="SemiBold"
                   Foreground="#555" Margin="0,0,0,8"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                    Content="➕ Добавить"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="120"
                    Height="34"
                    Margin="8,0,0,0"
                    TabIndex="7"
                    Click="AddItemButton_Click"/>
                        <TextBox x:Name="AddQtyTextBox"
                     DockPanel.Dock="Right"
                     Style="{StaticResource InputStyle}"
                     Text="1"
                     Width="96"
                     Height="34"
                     Padding="8,0"
                     TextAlignment="Center"
                     VerticalContentAlignment="Center"
                     Margin="8,0,0,0"
                     TabIndex="6"/>
                            <ComboBox x:Name="AddProductCombo"
                      Style="{StaticResource ComboInputStyle}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="ID_Product"
                      MaxDropDownHeight="200"
                      Height="34"
                      TabIndex="5"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Button x:Name="RemoveItemButton"
                        Content="🗑 Удалить выбранную позицию"
                        Style="{StaticResource DangerButtonStyle}"
                        HorizontalAlignment="Left"
                        Height="32" Margin="0,6,0,0"
                        Click="RemoveItemButton_Click"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C" FontSize="12"
                           Margin="0,12,0,0" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Отмена"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="36" TabIndex="9" Click="CancelButton_Click"/>
                    <Button Grid.Column="2" Content="Сохранить"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" TabIndex="8" IsDefault="True"
                            Click="SaveButton_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</local:DialogBase>