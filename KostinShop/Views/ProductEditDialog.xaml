<local:DialogBase x:Class="KostinShop.Views.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KostinShop.Views"
        Title="Товар"
        Height="420" Width="480"
        MinHeight="360" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/Resources/logo.png" Width="24" Height="24"
                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed"/>
                <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="Добавление товара"
                           Style="{StaticResource DialogHeaderTitleStyle}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,24,24,0"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Добавление товара"
                           Style="{StaticResource SectionTitleStyle}"/>

                <TextBlock Text="Название *" Style="{StaticResource FormLabelStyle}"/>
                <Grid Margin="0,0,0,8">
                <TextBox x:Name="NameTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="200" TabIndex="0"
                         HorizontalAlignment="Stretch"/>
                    <TextBlock IsHitTestVisible="False" Text="Введите название товара..."
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               Foreground="#AAAAAA" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=NameTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="Категория *" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="CategoryCombo"
                          Style="{StaticResource ComboInputStyle}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="ID_Category"
                          TabIndex="1" Margin="0,0,0,8"
                          HorizontalAlignment="Stretch"/>

                <TextBlock Text="Цена (₽) *" Style="{StaticResource FormLabelStyle}"/>
                <Grid Margin="0,0,0,8">
                <TextBox x:Name="PriceTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="12" TabIndex="2"
                         HorizontalAlignment="Stretch"/>
                    <TextBlock IsHitTestVisible="False" Text="Например: 1999.99"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               Foreground="#AAAAAA" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=PriceTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="Описание" Style="{StaticResource FormLabelStyle}"/>
                <Grid>
                <TextBox x:Name="DescriptionTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="1000" Height="80"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         TabIndex="3"
                         HorizontalAlignment="Stretch"/>
                    <TextBlock IsHitTestVisible="False" Text="Краткое описание товара (необязательно)"
                               VerticalAlignment="Top" Margin="10,8,0,0"
                               Foreground="#AAAAAA" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=DescriptionTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C" FontSize="12"
                           Margin="0,8,0,0" Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="24,12,24,16">
            <Button Margin="0,0,8,0" Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="90" IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" IsDefault="True" Click="SaveButton_Click" TabIndex="4"/>
        </StackPanel>
    </Grid>
</local:DialogBase>
