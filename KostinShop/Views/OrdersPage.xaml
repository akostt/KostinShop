<Page x:Class="KostinShop.Views.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"  MinHeight="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ToolbarCardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="6,0,0,6"/>

                <StackPanel Grid.Column="1" Margin="16,12" VerticalAlignment="Center" MinWidth="80">
                    <TextBlock Text="📋 Заказы" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Список заказов" Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#E8E8E8" Margin="0,10"/>

                <Grid Grid.Column="3" Margin="16,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Фильтр по статусу:"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center" Margin="0"/>
                        <ComboBox x:Name="StatusFilterCombo" Grid.Column="2"
                                  Height="34"
                                  Style="{StaticResource ComboInputStyle}"
                                  SelectionChanged="StatusFilter_Changed"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ProcessOrderButton"
                                Content="✅ Оформить" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="ProcessOrderButton_Click"/>
                        <Button x:Name="EditOrderButton"
                                Content="🖊 Изменить заказ" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="EditOrderButton_Click"/>
                        <Button x:Name="ChangeStatusButton"
                                Content="✏️ Статус" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="ChangeStatusButton_Click"/>
                        <Button x:Name="ChangeAddressButton"
                                Content="📍 Адрес" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="ChangeAddressButton_Click"/>
                        <Button x:Name="ManageItemsButton"
                                Content="📦 Позиции" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="ManageItemsButton_Click"/>
                        <Button x:Name="CancelOrderButton"
                                Content="🚫 Отменить" Style="{StaticResource DangerButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="CancelOrderButton_Click"/>
                        <Button x:Name="ExportOrderButton"
                                Content="📥 Экспорт" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                                Visibility="Collapsed" Click="ExportOrderButton_Click"/>
                        <Button x:Name="DeleteButton"
                                Content="🗑 Удалить"  Style="{StaticResource DangerButtonStyle}"    Margin="0,0,6,0" Click="DeleteButton_Click"/>
                        <Button Content="↺ Обновить" Style="{StaticResource SecondaryButtonStyle}"               Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="OrdersDataGrid" Grid.Row="1"
                  Style="{StaticResource DataGridStyle}"
                  SelectionChanged="OrdersDataGrid_SelectionChanged"
                  MouseDoubleClick="OrdersDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"         Binding="{Binding ID_Order}"  Width="55"/>
                <DataGridTextColumn Header="Дата"      Binding="{Binding Order_date, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                <DataGridTextColumn Header="Клиент"    Binding="{Binding ClientFullName}" Width="*"/>
                <DataGridTextColumn Header="Статус"    Binding="{Binding Status}"    Width="120"/>
                <DataGridTextColumn Header="Адрес"     Binding="{Binding Delivery_Address}" Width="2*"/>
                <DataGridTextColumn Header="Позиций"   Binding="{Binding ItemCount}" Width="75"/>
                <DataGridTextColumn Header="Сумма (₽)" Binding="{Binding OrderTotal, StringFormat='{}{0:N2}'}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="6" Margin="0,10,0,8" Padding="12,8,12,8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="#CCCCCC" Opacity="0.2"/>
            </Border.Effect>
            <DockPanel>
                <Border DockPanel.Dock="Left" Width="3" Background="{StaticResource SecondaryBrush}"
                        CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="Состав выбранного заказа"
                           Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="OrderItemsDataGrid" Grid.Row="3"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар"     Binding="{Binding ProductName}" Width="2*"/>
                <DataGridTextColumn Header="Цена на момент заказа" Binding="{Binding Price_at_order, StringFormat='{}{0:N2}'}" Width="170"/>
                <DataGridTextColumn Header="Кол-во"    Binding="{Binding Quantity}"    Width="80"/>
                <DataGridTextColumn Header="Сумма (₽)" Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
