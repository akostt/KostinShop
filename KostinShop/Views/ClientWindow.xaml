<Window x:Class="KostinShop.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KostinShop — Личный кабинет"
        Height="700" Width="1060"
        MinHeight="560" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Window.Resources>
        <Style x:Key="CategoryCardStyle" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="Margin"       Value="6"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#BBBBBB" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="Margin"       Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#BBBBBB" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Height="60">
            <DockPanel Margin="16,0">
                <Image Source="/Resources/logo.png" Width="34" Height="34"
                       VerticalAlignment="Center" DockPanel.Dock="Left"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="KostinShop" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"
                           Margin="8,0,0,0" DockPanel.Dock="Left"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="WelcomeTextBlock"
                               Foreground="{StaticResource TextWhiteBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                    <Button Content="✕ Закрыть"
                            Style="{StaticResource DangerButtonStyle}"
                            Padding="12,6" Click="LogoutButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl BorderThickness="0" Background="{StaticResource BackgroundBrush}">

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖥️" Margin="0,0,5,0"/>
                        <TextBlock Text="Каталог"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ToolbarCardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="6,0,0,6"/>

                            <StackPanel Grid.Column="1" Margin="16,12" VerticalAlignment="Center" MinWidth="80">
                                <TextBlock x:Name="CatalogTitleText" Text="🖥️ Каталог" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="CatalogSubtitleText" Text="Выберите категорию" Style="{StaticResource PageSubtitleStyle}"/>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#E8E8E8" Margin="0,10"/>

                            <Grid Grid.Column="3" Margin="16,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox x:Name="CatalogSearchBox"
                                         Grid.Row="0"
                                         Height="34"
                                         Style="{StaticResource InputStyle}"
                                         VerticalContentAlignment="Center"
                                         Padding="8,0"
                                         Tag="🔍 Поиск по всем товарам..."
                                         TextChanged="CatalogSearchBox_TextChanged"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BackToCategoriesButton"
                                            Content="← Категории"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,6,0"
                                            Visibility="Collapsed"
                                            Click="BackToCategories_Click"/>
                                    <Button Content="↺ Обновить"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ResetFilter_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="CategoriesView" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="CategoriesPanel"
                                   Margin="2"
                                   ItemWidth="200" ItemHeight="120"/>
                    </ScrollViewer>

                    <Grid x:Name="ProductsView" Grid.Row="1" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="ProductsPanel"
                                       Margin="2"
                                       ItemWidth="230" ItemHeight="160"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛒" Margin="0,0,5,0"/>
                        <TextBlock Text="Корзина"/>
                        <Border x:Name="CartBadge"
                                Background="{StaticResource PrimaryDarkBrush}"
                                CornerRadius="8" Padding="5,1" Margin="6,0,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="CartCountText" Text="0"
                                       FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="CartDataGrid" Grid.Row="0"
                              Style="{StaticResource DataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар"    Binding="{Binding ProductName}" Width="2*"/>
                            <DataGridTextColumn Header="Цена (₽)" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="100"/>
                            <DataGridTemplateColumn Header="Количество" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="−" Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="8,2" Tag="{Binding ID_Cart}"
                                                    Click="DecreaseQty_Click"/>
                                            <TextBlock Text="{Binding Quantity}"
                                                       VerticalAlignment="Center" Width="32"
                                                       TextAlignment="Center" FontWeight="SemiBold"/>
                                            <Button Content="+" Style="{StaticResource PrimaryButtonStyle}"
                                                    Padding="8,2" Tag="{Binding ID_Cart}"
                                                    Click="IncreaseQty_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Сумма (₽)" Binding="{Binding Total, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Style="{StaticResource DangerButtonStyle}"
                                                Padding="6,3" Tag="{Binding ID_Cart}"
                                                Click="RemoveFromCart_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,10">
                                <TextBlock DockPanel.Dock="Left" Text="Адрес:"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="DeliveryAddressTextBox"
                                         Style="{StaticResource InputStyle}"
                                         Tag="Например: г. Владимир, ул. Ленина, д. 1"
                                         MaxLength="500"/>
                            </DockPanel>

                            <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock DockPanel.Dock="Left" Text="Списать баллы:"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="LoyaltyBalanceTextBlock"
                                           DockPanel.Dock="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource PrimaryDarkBrush}"
                                           FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0"/>
                                <TextBox x:Name="PointsToSpendTextBox"
                                         Style="{StaticResource InputStyle}"
                                         Width="110" Text="0" MaxLength="7"
                                         TextChanged="PointsToSpend_TextChanged"/>
                            </DockPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock x:Name="CartTotalTextBlock"
                                           Text="Итого: 0,00 ₽"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryDarkBrush}"
                                           HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBlock x:Name="DiscountTextBlock"
                                           FontSize="12" Foreground="#888888"
                                           HorizontalAlignment="Right"
                                           Visibility="Collapsed" Margin="0,0,0,8"/>
                                <Button Content="Оформить заказ →"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="38" Padding="20,0"
                                        HorizontalAlignment="Right"
                                        Click="PlaceOrder_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" Margin="0,0,5,0"/>
                        <TextBlock Text="Мои заказы"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"  MinHeight="80"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="MyOrdersDataGrid" Grid.Row="0"
                              Style="{StaticResource DataGridStyle}"
                              SelectionChanged="MyOrdersDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№ заказа" Binding="{Binding ID_Order}"  Width="80"/>
                            <DataGridTextColumn Header="Дата"     Binding="{Binding Order_date, StringFormat='dd.MM.yyyy HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Адрес"    Binding="{Binding Delivery_Address}" Width="2*"/>
                            <DataGridTextColumn Header="Статус"   Binding="{Binding Status}"    Width="120"/>
                            <DataGridTextColumn Header="Сумма (₽)" Binding="{Binding OrderTotal, StringFormat='{}{0:N2}'}" Width="120"/>
                            <DataGridTextColumn Header="Позиций"  Binding="{Binding ItemCount}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}"
                            Margin="0,10,0,8" Padding="12,8">
                        <TextBlock Text="Состав выбранного заказа"
                                   Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                    </Border>

                    <DataGrid x:Name="MyOrderItemsDataGrid" Grid.Row="2"
                              Style="{StaticResource DataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар"    Binding="{Binding ProductName}" Width="2*"/>
                            <DataGridTextColumn Header="Цена на момент заказа" Binding="{Binding Price_at_order, StringFormat='{}{0:N2}'}" Width="170"/>
                            <DataGridTextColumn Header="Кол-во"   Binding="{Binding Quantity}"    Width="80"/>
                            <DataGridTextColumn Header="Сумма (₽)" Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
