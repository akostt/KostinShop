<local:DialogBase x:Class="KostinShop.Views.ManageOrderItemsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KostinShop.Views"
        Title="Состав заказа — KostinShop"
        Height="520" Width="580"
        MinHeight="420" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <TextBlock x:Name="TitleTextBlock" Text="Управление составом заказа"
                       Style="{StaticResource DialogHeaderTitleStyle}"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,2,0">
            <StackPanel Margin="24,16,24,8">
                <TextBlock Text="Текущие позиции" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                <DataGrid x:Name="ItemsGrid"
                          Style="{StaticResource DataGridStyle}"
                          Height="180"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар"  Binding="{Binding ProductName}" Width="2*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Цена"   Binding="{Binding Price_at_order, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сумма"  Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="90" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button x:Name="RemoveItemButton"
                        Content="🗑 Удалить выбранную позицию"
                        Style="{StaticResource DangerButtonStyle}"
                        HorizontalAlignment="Left"
                        Height="32" Margin="0,8,0,0"
                        Click="RemoveItemButton_Click"/>

                <Border Background="#F5F7FA" CornerRadius="6" Padding="0,10" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Добавить позицию" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="AddProductCombo"
                                      Grid.Column="0"
                                      Style="{StaticResource ComboInputStyle}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="ID_Product"
                                      MaxDropDownHeight="200"
                                      Height="34" TabIndex="1"/>

                            <TextBox x:Name="AddQtyTextBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputStyle}"
                                     Text="1"
                                     Height="34"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Padding="0"
                                     TabIndex="2"/>

                            <Button Grid.Column="4"
                                    Content="➕ Добавить"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34" TabIndex="3"
                                    Click="AddItemButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C" FontSize="12"
                           Margin="0,10,0,4" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,12">
            <Button Content="Закрыть"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Right"
                    Width="110" Height="34"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </Border>
    </Grid>
</local:DialogBase>
