<local:DialogBase x:Class="KostinShop.Views.ClientEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KostinShop.Views"
        Title="Редактирование клиента"
        Height="400" Width="460"
        MinHeight="340" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/Resources/logo.png" Width="24" Height="24"
                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed"/>
                <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="Редактирование клиента"
                           Style="{StaticResource DialogHeaderTitleStyle}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,0"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <TextBlock Text="Имя *" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="FirstNameTextBox"
                         Style="{StaticResource InputStyle}"
                         Tag="Например: Иван"
                         MaxLength="50" TabIndex="0" Margin="0,0,0,10"
                         IsReadOnly="True"
                         Background="#F5F5F5"
                         HorizontalAlignment="Stretch"/>

                <TextBlock Text="Отчество" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="MiddleNameTextBox"
                         Style="{StaticResource InputStyle}"
                         Tag="Необязательно"
                         MaxLength="50" TabIndex="1" Margin="0,0,0,10"
                         IsReadOnly="True"
                         Background="#F5F5F5"
                         HorizontalAlignment="Stretch"/>

                <TextBlock Text="Фамилия *" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="LastNameTextBox"
                         Style="{StaticResource InputStyle}"
                         Tag="Например: Иванов"
                         MaxLength="50" TabIndex="2" Margin="0,0,0,10"
                         HorizontalAlignment="Stretch"/>

                <TextBlock Text="Телефон *" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="PhoneTextBox"
                         Style="{StaticResource InputStyle}"
                         Tag="+7 (___) ___-__-__"
                         MaxLength="20" TabIndex="3" Margin="0,0,0,10"
                         HorizontalAlignment="Stretch"/>

                <TextBlock Text="Бонусные баллы 🎁" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="LoyaltyPointsTextBox"
                         Style="{StaticResource InputStyle}"
                         Tag="0"
                         MaxLength="7" TabIndex="4" Margin="0,0,0,4"
                         HorizontalAlignment="Stretch"/>
                <TextBlock Text="1 балл = 1 ₽ скидки при следующем заказе"
                           FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C" FontSize="12"
                           Visibility="Collapsed" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="24,12,24,16">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="90" Margin="0,0,8,0" IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" IsDefault="True" Click="SaveButton_Click" TabIndex="5"/>
        </StackPanel>
    </Grid>
</local:DialogBase>
