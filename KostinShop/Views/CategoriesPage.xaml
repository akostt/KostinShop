<views:CategoriesPageBase x:Class="KostinShop.Views.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="clr-namespace:KostinShop.Views"
      Title="Категории">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ToolbarCardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="6,0,0,6"/>

                <StackPanel Grid.Column="1" Margin="16,12" VerticalAlignment="Center" MinWidth="80">
                    <TextBlock Text="📁 Категории" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Группы товаров" Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#E8E8E8" Margin="0,10"/>

                <Grid Grid.Column="3" Margin="16,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="SearchTextBox" Grid.Row="0"
                             Height="34"
                             Style="{StaticResource InputStyle}"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             Tag="🔍 Поиск по названию..."
                             TabIndex="0"
                             TextChanged="SearchTextBox_TextChanged"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnAdd" Content="+ Добавить"  Style="{StaticResource PrimaryButtonStyle}"   Margin="0,0,6,0" TabIndex="1" Click="AddButton_Click"/>
                        <Button x:Name="BtnEdit" Content="✏️ Изменить" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" TabIndex="2" Click="EditButton_Click"/>
                        <Button x:Name="BtnDelete" Content="🗑 Удалить"  Style="{StaticResource DangerButtonStyle}"    Margin="0,0,6,0" TabIndex="3" Click="DeleteButton_Click"/>
                        <Button x:Name="BtnRefresh" Content="↺ Обновить" Style="{StaticResource SecondaryButtonStyle}"               TabIndex="4" Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="CategoriesDataGrid" Grid.Row="1"
                  Style="{StaticResource DataGridStyle}"
                  MouseDoubleClick="CategoriesDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название"       Binding="{Binding Name}"         Width="*"/>
                <DataGridTextColumn Header="Кол-во товаров" Binding="{Binding ProductCount}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</views:CategoriesPageBase>
