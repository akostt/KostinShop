<views:ClientsPageBase x:Class="KostinShop.Views.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="clr-namespace:KostinShop.Views"
      Title="Клиенты">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ToolbarCardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="6,0,0,6"/>

                <StackPanel Grid.Column="1" Margin="16,12" VerticalAlignment="Center" MinWidth="80">
                    <TextBlock Text="👥 Клиенты" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="База покупателей" Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#E8E8E8" Margin="0,10"/>

                <Grid Grid.Column="3" Margin="16,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="SearchTextBox" Grid.Row="0"
                             Height="34"
                             Style="{StaticResource InputStyle}"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             Tag="🔍 Поиск по имени / телефону..."
                             TextChanged="SearchTextBox_TextChanged"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnEdit" Content="✏️ Изменить" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="EditButton_Click"/>
                        <Button x:Name="BtnDelete" Content="🗑 Удалить"  Style="{StaticResource DangerButtonStyle}"    Margin="0,0,6,0" Click="DeleteButton_Click"/>
                        <Button x:Name="BtnRefresh" Content="↺ Обновить" Style="{StaticResource SecondaryButtonStyle}"               Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="ClientsDataGrid" Grid.Row="1"
                  Style="{StaticResource DataGridStyle}"
                  MouseDoubleClick="ClientsDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия"  Binding="{Binding Last_Name}"   Width="*"/>
                <DataGridTextColumn Header="Имя"      Binding="{Binding First_Name}"  Width="*"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Middle_Name}" Width="*"/>
                <DataGridTextColumn Header="Телефон"  Binding="{Binding Phone}"       Width="160"/>
                <DataGridTextColumn Header="Баллы 🎁" Binding="{Binding Loyalty_Points}" Width="90"/>
                <DataGridTextColumn Header="Заказов"  Binding="{Binding OrderCount}"  Width="80"/>
                <DataGridTextColumn Header="С нами с" Binding="{Binding Registered_At, StringFormat='dd.MM.yyyy'}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</views:ClientsPageBase>
