<Window x:Class="KostinShop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KostinShop — Авторизация"
        Height="520" Width="420"
        MinHeight="440" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="130"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <Image Source="/Resources/logo.png" Width="40" Height="40"
                           HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="KostinShop" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="Интернет-магазин электроники" FontSize="11"
                               Foreground="{StaticResource TextWhiteBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Padding="40,24">
                <StackPanel>
                    <TextBlock Text="Вход в систему"
                               Style="{StaticResource SectionTitleStyle}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <TextBlock Text="Логин" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="LoginTextBox"
                             Style="{StaticResource InputStyle}"
                             Tag="Введите логин..."
                             Margin="0,0,0,12" TabIndex="0"/>

                    <TextBlock Text="Пароль" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource PasswordInputStyle}"
                                 Margin="0,0,0,6" TabIndex="1"
                                 KeyDown="PasswordBox_KeyDown"/>

                    <TextBlock x:Name="ErrorTextBlock"
                               Foreground="#E74C3C" FontSize="12"
                               Margin="0,0,0,12" Visibility="Collapsed"
                               TextWrapping="Wrap"/>

                    <Button Content="Войти"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="38" Margin="0,0,0,10"
                            TabIndex="2" IsDefault="True" Click="LoginButton_Click"/>

                    <Button Content="Регистрация нового покупателя"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="38" TabIndex="3"
                            Click="RegisterButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
