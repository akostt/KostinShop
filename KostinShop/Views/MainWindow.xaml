<Window x:Class="KostinShop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KostinShop — Главная"
        Height="650" Width="1100"
        MinHeight="550" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/logo.png"
        Style="{StaticResource BaseWindowStyle}">

    <Window.Resources>
        <Storyboard x:Key="ExpandSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder"
                             Storyboard.TargetProperty="Width"
                             To="200" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CollapseSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder"
                             Storyboard.TargetProperty="Width"
                             To="56" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <DockPanel>
        <!-- ═══════ HEADER ═══════ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Height="60">
            <DockPanel Margin="0,0,16,0">
                <!-- Бургер-кнопка -->
                <Button x:Name="ToggleSidebarButton"
                        Width="56" Height="60"
                        DockPanel.Dock="Left"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="ToggleSidebar_Click"
                        ToolTip="Свернуть / развернуть меню">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="20">
                                    <Rectangle Height="2" Fill="White" Margin="0,0,0,4" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Height="2" Fill="White" Margin="0,0,0,4" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Height="2" Fill="White" RadiusX="1" RadiusY="1"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Логотип -->
                <Image Source="/Resources/logo.png" Width="34" Height="34"
                       VerticalAlignment="Center" DockPanel.Dock="Left" Margin="4,0,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="KostinShop" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"
                           Margin="8,0,0,0" DockPanel.Dock="Left"/>
                <!-- Пользователь + выход -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentUserTextBlock"
                               Foreground="{StaticResource TextWhiteBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                    <Button Content="Выход"
                            Style="{StaticResource DangerButtonStyle}"
                            Padding="12,6" Click="LogoutButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════ SIDEBAR + CONTENT ═══════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковая панель -->
            <Border x:Name="SidebarBorder"
                    Grid.Column="0"
                    Width="56"
                    Background="{StaticResource PrimaryBrush}">
                <Border.Effect>
                    <DropShadowEffect Direction="0" ShadowDepth="3"
                                      BlurRadius="8" Color="#000000" Opacity="0.10"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NavPanel" Margin="0,8,0,8">

                        <Button x:Name="NavCategories" Tag="Categories" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Категории">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📦" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblCategories" Text="  Категории" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavProducts" Tag="Products" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Товары">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🖥️" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblProducts" Text="  Товары" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavClients" Tag="Clients" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Клиенты">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblClients" Text="  Клиенты" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavOrders" Tag="Orders" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Заказы">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📋" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblOrders" Text="  Заказы" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavStatuses" Tag="Statuses" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Статусы">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔖" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblStatuses" Text="  Статусы" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavUsers" Tag="Users" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Пользователи"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👑" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblUsers" Text="  Пользователи" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="10,8" Background="{StaticResource PrimaryDarkBrush}"/>

                        <Button x:Name="NavMyOrders" Tag="MyOrders" Click="NavButton_Click"
                                Style="{StaticResource NavButtonStyle}" ToolTip="Мой кабинет"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🛒" FontSize="15" Width="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblMyOrders" Text="  Мой кабинет" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Контент -->
            <Frame x:Name="ContentFrame"
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BackgroundBrush}"/>
        </Grid>
    </DockPanel>
</Window>
